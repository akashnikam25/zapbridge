# =============================================================================
# zapbridge environment template — copy to .env and fill in real values.
#   cp .env.example .env
# =============================================================================

# --- Infrastructure (consumed by docker-compose.yml AND the app) ---
POSTGRES_USER=zapbridge
POSTGRES_PASSWORD=change-me-to-a-strong-secret
POSTGRES_DB=zapbridge
POSTGRES_PORT=5433
REDIS_PORT=6380

# --- App connection strings (keep host/port/creds in sync with the block above) ---
DATABASE_URL=postgresql://zapbridge:change-me-to-a-strong-secret@localhost:5433/zapbridge
REDIS_URL=redis://localhost:6380

# --- Third-party integrations (see slices/slice-00-prerequisites.md) ---
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_WEBHOOK_SECRET=
ANTHROPIC_API_KEY=sk-ant-...

# --- Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=
